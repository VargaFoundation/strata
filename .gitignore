# Rust build artifacts
/target/
**/*.rs.bk

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.Zone.Identifier

# Environment
.env
.env.*
!.env.example

# Editor backup
*.orig
*.rej

# Coverage / profiling
*.profraw
lcov.info
tarpaulin-report.html
coverage/

# Runtime data
/data/
**/data/*.duckdb
**/data/*.db-shm
**/data/*.db-wal

# Docker
docker-compose.override.yml

# Misc
*.log

# Runtime data stores (DuckDB / SQLite / USearch / Raft logs) — never commit.
# Ignore the whole runtime data tree so test runs (which write ./data) don't leak artifacts.
**/data/
**/data/*.duckdb
**/data/*.duckdb.wal
**/data/*.db
**/data/*.db-wal
**/data/*.db-shm
**/data/state.db
**/data/raft/
**/data/wal/
**/data/backups/
**/data/*.usearch

# fastembed model cache (rerank-local)
.fastembed_cache/
